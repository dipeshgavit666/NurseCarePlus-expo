{
  "expo": {
    "name": "NurseCare+",
    "slug": "nursecare-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nursecare",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0EA5E9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nursecare.plus",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NurseCare+ uses your location to share with caregivers during an SOS emergency."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0EA5E9"
      },
      "package": "com.nursecare.plus",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SEND_SMS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NurseCare+ to use the camera to scan QR codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0EA5E9"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NurseCare+ to access your location for SOS emergencies."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1820e2c9-7cba-44ad-a683-45de15966163"
      }
    },
    "owner": "dipesh-dev"
  }
}
